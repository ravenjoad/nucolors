\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{nucolors}[2023/07/24 Northwestern University Colors]
\PackageInfo{nucolors}{Color information taken from https://www.northwestern.edu/brand/visual-identity/color-palettes/}

\RequirePackage{kvoptions}
% Provides \NewDocumentCommand
% https://www.texdev.net/2010/05/23/from-newcommand-to-newdocumentcommand/
% \RequirePackage{xparse}

\RequirePackage{xcolor}

\SetupKeyvalOptions{
  family=nucolors,
  prefix=nucolors@
}

% Change styles depending on the type of output
\DeclareBoolOption[true]{digital}
% Default digital to true. You only switch to printing at the end
\DeclareComplementaryOption{print}{digital}

\DeclareBoolOption{coated}% If print, coated or uncoated?
% Default to false on coated, because coated paper is rarer.

\DeclareBoolOption{secondary}% Provide secondary color palette
% Default to false

\DeclareOption*{%
  \PackageWarning{nucolors}{Unknown option(s) '\CurrentOption'}%
}

\ExecuteOptions{output}
\ProcessKeyvalOptions*

% If the user only provides coated, switch to print output
\ifnucolors@coated
  \nucolors@printtrue
\fi

